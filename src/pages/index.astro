---
import BaseHead from "../components/BaseHead.astro";
import "../styles/global.css";
import { Image } from "astro:assets";
import billete10 from "../assets/billete10.jpg";
import billete20 from "../assets/billete20.jpg";
import billete50 from "../assets/billete50.jpg";
import qr from "../assets/qr.jpg";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<BaseHead
			title="Verifica Mi Billete Bolivia"
			description="Verifica facil y rapido tu billete"
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<header class="navbar">
			<div class="logo">VMB<span>Bolivia</span></div>
			<div
				class="header-buttons"
				style="display: flex; gap: 12px; align-items: center;"
			>
				<a
					href="https://github.com/qitsikasa/ChecaMiBillete"
					target="_blank"
					rel="noopener noreferrer"
					class="btn-github-top"
				>
					<svg
						height="20"
						width="20"
						viewBox="0 0 16 16"
						fill="currentColor"
					>
						<path
							d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
						></path>
					</svg>
					GitHub
				</a>
				<a href="#donaciones" class="btn-donate-top">
					<svg
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path
							d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
						></path></svg
					>
					Donar
				</a>
			</div>
		</header>

		<main>
			<section class="hero">
				<h1>Verifica Mi Billete Bolivia</h1>
				<p class="tagline">Verifica fácil y rápido tu billete</p>

				<div class="glass-panel">
					<form id="verificaForm">
						<p>
							Por favor, selecciona la denominación de tu billete:
						</p>
						<div class="denomination-selector">
							<input
								type="radio"
								id="den-10"
								name="denomination"
								value="10"
								checked
							/>
							<label for="den-10">10 Bs</label>
							<input
								type="radio"
								id="den-20"
								name="denomination"
								value="20"
							/>
							<label for="den-20">20 Bs</label>
							<input
								type="radio"
								id="den-50"
								name="denomination"
								value="50"
							/>
							<label for="den-50">50 Bs</label>
						</div>
						<p>
							Por favor, ingresa el numero de serie de tu billete:
						</p>
						<div class="input-group">
							<input
								type="text"
								id="serieNumber"
								placeholder="Ingresa los números..."
								maxlength="12"
								required
								autocomplete="off"
							/>
							<span class="suffix">B</span>
						</div>
						<button type="submit" class="btn-primary"
							>Verificar Billete</button
						>
						<div id="result" class="result-message"></div>
					</form>
				</div>
			</section>

			<section id="billetes-inhabilitados" class="section-container">
				<h2>Billetes Inhabilitados</h2>
				<p>
					A continuación mostramos la lista oficial inhabilitada por
					el BCB
				</p>
				<div class="vertical-images">
					<div class="image-card">
						<Image
							src={billete10}
							alt="Billete de 10 Bs inhabilitado"
						/>
					</div>
					<div class="image-card">
						<Image
							src={billete20}
							alt="Billete de 20 Bs inhabilitado"
						/>
					</div>
					<div class="image-card">
						<Image
							src={billete50}
							alt="Billete de 50 Bs inhabilitado"
						/>
					</div>
				</div>
			</section>

			<section id="donaciones" class="section-container">
				<h2>Apoya Nuestro Proyecto</h2>
				<p>
					Si esta herramienta te fue de ayuda, considera apoyarnos con
					una donación para mantener el sitio activo.
				</p>
				<div class="qr-container">
					<div class="qr-wrapper">
						<!-- Instrucción para el usuario: cambia la URL en src y quita la clase hidden -->
						<Image src={qr} alt="QR de Donación" id="qr-image" />
					</div>
					<p
						style="margin: 0; font-weight: 600; color: var(--primary);"
					>
						¡Gracias por tu apoyo!
					</p>
				</div>
			</section>

			<div
				style="text-align: center; margin-top: 2rem; padding-bottom: 2rem;"
			>
				<img
					src="https://api.visitorbadge.io/api/visitors?path=verificamibilletebolivia&label=Visitas&countColor=%232cc295&labelStyle=upper"
					alt="Contador de visitas"
				/>
			</div>
		</main>

		<script>
			// Base de datos de rangos inhabilitados
			// El formato es: 'denominacion': [[inicio1, fin1], [inicio2, fin2], ...]
			const rangosInhabilitados: Record<string, [number, number][]> = {
				"10": [
					[67250001, 67700000],
					[69050001, 69500000],
					[69550001, 69950000],
					[69950001, 70400000],
					[70400001, 70850000],
					[70850001, 71300000],
					[76310012, 85139995],
					[86400001, 86850000],
					[90900001, 91350000],
					[91800001, 92250000],
				],
				"20": [
					[87280145, 91646549],
					[96650001, 97100000],
					[99800001, 100250000],
					[100250001, 100700000],
					[109250001, 109700000],
					[110600001, 111050000],
					[111050001, 111500000],
					[111950001, 112400000],
					[112400001, 112850000],
					[112850001, 113300000],
					[114200001, 114650000],
					[114650001, 115100000],
					[115100001, 115550000],
					[118750001, 119150000],
					[119150001, 119600000],
					[120500001, 120950000],
				],
				"50": [
					[77100001, 77550000],
					[78000001, 78450000],
					[78900001, 96350000],
					[96350001, 96800000],
					[96800001, 97250000],
					[98150001, 98600000],
					[104900001, 105350000],
					[105350001, 105800000],
					[106700001, 107150000],
					[107600001, 108050000],
					[108050001, 108500000],
					[109400001, 109850000],
				],
			};

			// Función interna requerida
			// Retorna verdadero (true) si el billete NO está en la lista de inhabilitados
			function verificarbillete(
				serie: string,
				denomination: string,
			): boolean {
				// Convertimos la serie a un número entero para hacer la comparación
				const numeroSerie = parseInt(serie, 10);

				// Buscamos los rangos inhabilitados para esta denominación
				const rangos = rangosInhabilitados[denomination] || [];

				// Comprobamos si el número de la serie existe dentro de algún rango
				for (const rango of rangos) {
					const [inicio, fin] = rango;
					if (numeroSerie >= inicio && numeroSerie <= fin) {
						// El billete está en un rango inhabilitado, ¡es falso o robado!
						return false;
					}
				}

				// Si no coincidió con ningún rango peligroso, pasa como válido
				return true;
			}

			const form = document.getElementById("verificaForm");
			const resultDiv = document.getElementById("result");
			const serieInput = document.getElementById("serieNumber");

			if (form && resultDiv && serieInput) {
				const inputEl = serieInput as HTMLInputElement;

				// Limitar input a solo números en tiempo real
				inputEl.addEventListener("input", (e) => {
					let val = inputEl.value;
					val = val.replace(/[^0-9]/g, "");
					inputEl.value = val;
				});

				form.addEventListener("submit", (e) => {
					e.preventDefault();

					const serieNumber = inputEl.value.trim();

					if (!serieNumber) {
						resultDiv.textContent =
							"Ingresa un número de serie válido.";
						resultDiv.className = "result-message error";
						return;
					}

					// Obtener la denominación seleccionada
					const denominationEl = document.querySelector(
						'input[name="denomination"]:checked',
					) as HTMLInputElement;
					const denominationValue = denominationEl
						? denominationEl.value
						: "10";

					// Verificar el billete llamando a la función
					const esValido = verificarbillete(
						serieNumber,
						denominationValue,
					);

					if (esValido) {
						resultDiv.innerHTML = `<strong>Verificación exitosa:</strong><br>El billete de ${denominationValue} Bs de serie ${serieNumber} es válido.`;
						resultDiv.className = "result-message success";
					} else {
						resultDiv.innerHTML = `<strong>Alerta:</strong><br>Este billete pertenece a la lista inhabilitada por el BCB`;
						resultDiv.className = "result-message error";
					}
				});
			}
		</script>
	</body>
</html>
